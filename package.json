{
  "name": "pestsentinel-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Pest Sentinel — real-time pest risk intelligence across 500+ zones in the US and Canada",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pestsentinel-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "pest-control",
    "pest-intelligence",
    "risk-scores",
    "geospatial",
    "pest-sentinel"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "express": "^4.18.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
